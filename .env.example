# Copy this to .env (gitignored) and fill in your values.
# The .env file is auto-loaded by src/auth.js; stream-server.js reads it transitively.

# Signing key for session cookies. Generate one with:
#   openssl rand -hex 32
SESSION_SECRET=

# Which transactional-email provider to use. 'resend' = Resend HTTP API
# (recommended — 3k free/month, verify mugenbattle.com via DNS records in
# Cloudflare). 'gmail' = Gmail OAuth2 (legacy). Unset = print code to
# stdout (dev only).
EMAIL_PROVIDER=resend

# From-address for login-code emails. Must be on a domain Resend (or Gmail)
# is authorised to send from.
EMAIL_FROM=noreply@mugenbattle.com

# --- Resend ---
# Get an API key at https://resend.com/api-keys after verifying
# mugenbattle.com in the Resend dashboard and adding its DNS records on
# Cloudflare (SPF TXT, DKIM TXT, return-path CNAME).
RESEND_API_KEY=

# --- Gmail (legacy fallback; only used when EMAIL_PROVIDER=gmail) ---
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Set NODE_ENV=production to:
#   - make cookies Secure-only
#   - refuse to send login codes when the mailer isn't configured
# NODE_ENV=production
