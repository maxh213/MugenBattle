# Copy this to .env (gitignored) and fill in your values.
# The .env file is auto-loaded by src/auth.js; stream-server.js reads it transitively.

# Signing key for session cookies. Generate one with:
#   openssl rand -hex 32
SESSION_SECRET=

# Gmail OAuth2 credentials — used to send 6-digit login codes.
# To set these up, follow Google's "OAuth 2.0 for Server-side Web Apps" flow
# (same pattern as any Gmail-API-from-a-server project). You need scope:
#   https://www.googleapis.com/auth/gmail.send
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER=mugenbattle@yourdomain.com

# Set NODE_ENV=production to:
#   - make cookies Secure-only
#   - refuse to send login codes when GMAIL_* is missing (dev just prints them)
# NODE_ENV=production
